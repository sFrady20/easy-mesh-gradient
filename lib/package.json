{
  "name": "easy-mesh-gradient",
  "version": "0.2.1",
  "description": "Generate beautiful CSS mesh gradients with easing. Zero dependencies, full TypeScript support.",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "main": "./dist/easy-mesh-gradient.umd.cjs",
  "module": "./dist/easy-mesh-gradient.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/easy-mesh-gradient.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/easy-mesh-gradient.umd.cjs"
      }
    }
  },
  "sideEffects": false,
  "keywords": [
    "mesh-gradient",
    "gradient",
    "css",
    "background",
    "generative",
    "color",
    "typescript"
  ],
  "homepage": "https://easy-mesh-gradient.stevenfrady.com",
  "author": {
    "name": "Steven Frady",
    "email": "sfrady20@gmail.com",
    "url": "https://stevenfrady.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sFrady20/easy-mesh-gradient.git",
    "directory": "lib"
  },
  "bugs": {
    "url": "https://github.com/sFrady20/easy-mesh-gradient/issues"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "^8.1.4",
    "vite-plugin-dts": "^5.0.3"
  },
  "scripts": {
    "build": "vite build",
    "type-check": "tsc --noEmit"
  }
}
