{
  "name": "easy-mesh-gradient-monorepo",
  "private": true,
  "workspaces": [
    "lib",
    "pages",
    "promo"
  ],
  "scripts": {
    "dev": "bun --cwd pages dev",
    "build": "bun --cwd lib build",
    "build:pages": "bun --cwd pages build",
    "lint": "eslint lib pages",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "bun --cwd lib type-check && bun --cwd pages type-check"
  },
  "devDependencies": {
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "prettier": "^3.9.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0"
  }
}
